GENERATION_PROVIDER=comfyui
OPENAI_API_KEY=your_key_here
OPENAI_RESPONSE_MODEL=gpt-5
OPENAI_DIAGNOSIS_MODEL=gpt-5
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_MODE=img2img
COMFYUI_WORKFLOW_PATH=./api/comfyui-workflows/furniture-txt2img.json
COMFYUI_IMG2IMG_WORKFLOW_PATH=./api/comfyui-workflows/furniture-img2img.json
COMFYUI_TIMEOUT_MS=600000
COMFYUI_POLL_INTERVAL_MS=2000
COMFYUI_DENOISE=0.45
COMFYUI_CHECKPOINT_NAME=your_checkpoint_name.safetensors
VITE_ENABLE_REAL_GENERATION=false
